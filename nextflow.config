/*
 * HOMES project-level Nextflow configuration.
 *
 * This file is for future HOMES-native workflows. nf-core pipelines can still
 * be run through the shell wrappers in workflows/*.
 */

manifest {
    name        = 'HOMES'
    description = 'Integrated microbiome workflows for HOMES'
    author      = 'Kaiqin Bian'
}

params {
    outdir = 'results'
}

profiles {
    docker {
        docker.enabled = true
    }

    local {
        process.executor = 'local'
    }
}

