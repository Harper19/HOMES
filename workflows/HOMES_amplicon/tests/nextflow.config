/*
========================================================================================
    Nextflow config file for running nf-test tests
========================================================================================
*/

// Or any resources requirements
params {
    modules_testdata_base_path = 'https://raw.githubusercontent.com/HOMES/test-datasets/modules/data/'
    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/HOMES/test-datasets/refs/heads/ampliseq/'
}

// Reproducible VSEARCH LCA output row order for snapshot tests (single thread via cpus).
process {
    withName: 'VSEARCH_USEARCHGLOBAL_LCA' {
        cpus = 1
    }
}

aws.client.anonymous = true // fixes S3 access issues on self-hosted runners
