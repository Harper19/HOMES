nextflow_pipeline {

    name "Test pipeline VSEARCH LCA"
    script "../main.nf"
    tag "test_vsearch_lca"
    tag "pipeline"
    profile "test_vsearch_lca"

    test("-profile test_vsearch_lca") {

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            def stable_path = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])

            assert workflow.success
            assertAll(
                { assert snapshot(
                    removeNextflowVersion("$outputDir/pipeline_info/homes_ampli_shortseq_software_mqc_versions.yml"),
                    stable_path,
                    path("$outputDir/vsearch_lca/ASV_tax_vsearch_lca.unite-fungi.tsv"),
                    path("$outputDir/vsearch_lca/ref_taxonomy_vsearch_lca.txt"),
                    path("$outputDir/dada2/ASV_table.tsv"),
                    path("$outputDir/multiqc/multiqc_data/multiqc_general_stats.txt")
                ).match() }
            )
        }
    }
}
